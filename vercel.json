{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://realtime-chat-demo-production.up.railway.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://realtime-chat-demo-production.up.railway.app/auth/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://realtime-chat-demo-production.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
